{
  "name": "slowgram",
  "version": "1.0.0",
  "description": "an alternative to posting on instagram. add a photo once in a while, no stories, no likes, no comments, no ads, no tracking, no algorithms, no notifications, no pressure. just a photo.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "clean:dist": "rm -rf dist",
    "clean:deps": "rm -rf node_modules",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{js,html,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,html,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "git config core.hooksPath .githooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/adimoldovan/slowgram.git"
  },
  "author": "Adrian Moldovan",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/adimoldovan/slowgram/issues"
  },
  "homepage": "https://github.com/adimoldovan/slowgram",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "dist-exiftool": "^10.53.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "imagemin": "^9.0.1",
    "imagemin-webp": "^8.0.0",
    "jsdom": "^29.0.1",
    "node-exiftool": "^2.3.0",
    "node-vibrant": "^4.0.4",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.2"
  }
}
